# Copy public configuration only. Never add a real key to this file.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
AI_PROVIDER_MODE=mock

# Public Google Cloud configuration used by the deployed runtime
GCP_PROJECT_ID=time-sovereignty-2026
FIRESTORE_DATABASE_ID=(default)
CLOUD_TASKS_LOCATION=asia-east1
CLOUD_TASKS_QUEUE=time-sovereignty-checkins
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=
CLOUD_TASKS_OIDC_AUDIENCE=
CLOUD_TASKS_CALLBACK_BASE_URL=
TASK_CALLBACK_LEASE_SECONDS=60

# Private single-device path. Keep disabled until both secrets are supplied
# through Secret Manager or another server-only secret store.
LIVE_CHECKIN_ENABLED=false
LIVE_CHECKIN_SESSION_HOURS=12
LIVE_CHECKIN_ALLOWED_ORIGINS=
LIVE_CHECKIN_PAIRING_SECRET=
LIVE_CHECKIN_SESSION_SECRET=
